<!DOCTYPE html>
<html lang="en" @ServerThemeAttributes>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Video Cortex</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr"
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="app.css" />
    <HeadOutlet />
    <script>
        // Apply the saved theme immediately to prevent a flash. Light/dark only — default dark.
        (function () {
            try {
                const saved = localStorage.getItem('videocortex-theme');
                const theme = saved === 'light' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { /* localStorage unavailable — server cookie fallback handles it */ }
        })();

        // Toggle + persist theme. Plain script so it works on statically-rendered pages too.
        window.vcToggleTheme = function () {
            try {
                const html = document.documentElement;
                const next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
                localStorage.setItem('videocortex-theme', next);
                document.cookie = 'videocortex-theme=' + next + ';path=/;max-age=31536000;SameSite=Lax';
                html.setAttribute('data-bs-theme', next);
            } catch (e) { }
        };
    </script>
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // Render data-bs-theme on <html> server-side from the cookie so the theme is correct before
    // JS runs (no flash after enhanced navigation). Default dark; only known values allowed.
    private MarkupString ServerThemeAttributes
    {
        get
        {
            var theme = HttpContext.Request.Cookies.TryGetValue("videocortex-theme", out var t) ? t : null;
            return theme == "light"
                ? new MarkupString("data-bs-theme=\"light\"")
                : new MarkupString("data-bs-theme=\"dark\"");
        }
    }
}
