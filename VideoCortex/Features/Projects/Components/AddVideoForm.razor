@inject IVideoCommands VideoCommands

<EditForm Model="@Model" OnValidSubmit="HandleSubmit" FormName="add-video">
    <div class="input-group">
        <InputText class="form-control" @bind-Value="Model.Input"
                   placeholder="YouTube URL or video ID" disabled="@_busy" />
        <button type="submit" class="btn btn-primary" disabled="@_busy">
            @(_busy ? "Adding…" : "Add Video")
        </button>
    </div>
</EditForm>

<p class="text-body-secondary small mt-1 mb-0">
    Pasted videos are queued for processing; the transcript and summary are fetched later.
</p>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-2 mb-0 py-2">@_message</div>
}

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public EventCallback OnVideoAdded { get; set; }

    private AddInputModel Model { get; set; } = new();
    private bool _busy;
    private string? _message;
    private string _alertClass = "alert-secondary";

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(Model.Input)) return;

        _busy = true;
        _message = null;
        try
        {
            var result = await VideoCommands.AddVideoByUrlAsync(ProjectId, Model.Input!);
            switch (result.Outcome)
            {
                case AddVideoOutcome.Added:
                    Model = new AddInputModel();
                    _message = $"Added {result.YoutubeVideoId}.";
                    _alertClass = "alert-success";
                    await OnVideoAdded.InvokeAsync();
                    break;
                default:
                    _message = result.Message;
                    _alertClass = "alert-warning";
                    break;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class AddInputModel
    {
        public string? Input { get; set; }
    }
}
