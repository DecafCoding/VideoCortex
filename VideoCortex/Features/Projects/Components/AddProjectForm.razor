@inject IProjectService ProjectService

<EditForm Model="@Model" OnValidSubmit="HandleSubmit" FormName="add-project">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label for="name" class="form-label">Name</label>
        <InputText id="name" class="form-control" @bind-Value="Model.Name" />
        <ValidationMessage For="() => Model.Name" class="text-danger small" />
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <InputTextArea id="description" class="form-control" rows="2" @bind-Value="Model.Description" />
    </div>

    <div class="mb-3">
        <label for="ai" class="form-label">AI Instructions</label>
        <InputTextArea id="ai" class="form-control" rows="2" @bind-Value="Model.AIInstructions" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@_busy">
        @(_busy ? "Creating…" : "Add Project")
    </button>
</EditForm>

@if (_message is not null)
{
    <div class="alert @_alertClass mt-3 mb-0 py-2">@_message</div>
}

@code {
    [Parameter] public EventCallback OnProjectAdded { get; set; }

    private ProjectFormModel Model { get; set; } = new();
    private bool _busy;
    private string? _message;
    private string _alertClass = "alert-secondary";

    private async Task HandleSubmit()
    {
        _busy = true;
        _message = null;
        try
        {
            var result = await ProjectService.CreateAsync(Model);
            if (result.Success)
            {
                Model = new ProjectFormModel();
                _message = "Project created.";
                _alertClass = "alert-success";
                await OnProjectAdded.InvokeAsync();
            }
            else
            {
                _message = result.ErrorMessage ?? "Could not create the project.";
                _alertClass = "alert-warning";
            }
        }
        finally
        {
            _busy = false;
        }
    }
}
