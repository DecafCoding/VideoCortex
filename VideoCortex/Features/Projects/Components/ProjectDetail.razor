@page "/projects/{Slug}"
@using System.IO
@using Microsoft.Extensions.Options
@using VideoCortex.Core.Services.Config
@inject IProjectService ProjectService
@inject NavigationManager Nav
@inject IOptions<LibrarySettings> LibraryOptions

<PageTitle>@(_project?.Name ?? "Project") — Video Cortex</PageTitle>

@if (_loading)
{
    <p class="muted">Loading…</p>
}
else if (_project is null)
{
    <h1>Project not found</h1>
    <p><a href="/projects">← Back to Projects</a></p>
}
else
{
    <p><a href="/projects">← Projects</a></p>
    <h1>@_project.Name</h1>

    @if (!string.IsNullOrWhiteSpace(_project.Description))
    {
        <p>@_project.Description</p>
    }
    <p class="meta">
        Created @_project.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd") · Status: @_project.Status
    </p>

    <p>
        <a href="@_libraryUri" target="_blank" rel="noopener">Open Library ↗</a>
    </p>
    <p class="muted">Library path: <code>@_libraryPath</code></p>

    <section class="panel">
        <h2>Videos</h2>
        <AddVideoForm ProjectId="_project.Id" OnVideoAdded="RefreshVideos" />
        <ProjectVideos @ref="_videos" ProjectId="_project.Id" />
    </section>

    <section class="danger-zone">
        <h2>Delete Project</h2>
        @if (!_confirmingDelete)
        {
            <button class="btn-danger" @onclick="() => _confirmingDelete = true">Delete Project</button>
        }
        else
        {
            <p>Delete <strong>@_project.Name</strong> from Video Cortex?</p>
            <label class="checkbox">
                <input type="checkbox" @bind="_alsoDeleteFolder" />
                Also delete the library folder on disk (by default the OKF files are kept)
            </label>
            <div class="actions">
                <button class="btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                    @(_deleting ? "Deleting…" : "Confirm Delete")
                </button>
                <button @onclick="() => _confirmingDelete = false" disabled="@_deleting">Cancel</button>
            </div>
            @if (_error is not null)
            {
                <p class="warn">@_error</p>
            }
        }
    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private ProjectDetailDto? _project;
    private ProjectVideos? _videos;
    private bool _loading = true;
    private bool _confirmingDelete;
    private bool _alsoDeleteFolder;
    private bool _deleting;
    private string? _error;
    private string _libraryUri = string.Empty;
    private string _libraryPath = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _project = await ProjectService.GetBySlugAsync(Slug);
        if (_project is not null)
        {
            _libraryPath = Path.Combine(
                LibraryOptions.Value.RootPath, _project.LibraryFolderName, "index.html");
            // file:// link so the on-disk library opens in a browser. Navigation from an
            // http:// page may be blocked by the browser — the plain path is shown too.
            _libraryUri = new Uri(_libraryPath).AbsoluteUri;
        }
        _loading = false;
    }

    private async Task RefreshVideos()
    {
        if (_videos is not null)
            await _videos.RefreshAsync();
    }

    private async Task ConfirmDelete()
    {
        _deleting = true;
        _error = null;
        var result = await ProjectService.DeleteAsync(_project!.Id, _alsoDeleteFolder);
        if (result.Success)
        {
            Nav.NavigateTo("/projects");
        }
        else
        {
            _error = result.ErrorMessage ?? "Delete failed.";
            _deleting = false;
        }
    }
}
