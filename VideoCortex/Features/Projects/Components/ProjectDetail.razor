@page "/projects/{Slug}"
@using System.IO
@using Microsoft.Extensions.Options
@using VideoCortex.Core.Services.Config
@inject IProjectService ProjectService
@inject NavigationManager Nav
@inject IOptions<LibrarySettings> LibraryOptions

<PageTitle>@(_project?.Name ?? "Project") — Video Cortex</PageTitle>

@if (_loading)
{
    <p class="text-body-secondary">Loading…</p>
}
else if (_project is null)
{
    <h1>Project not found</h1>
    <p><a href="projects">← Back to Projects</a></p>
}
else
{
    <div class="row">
        <aside class="col-lg-3 col-md-4 sidebar-content mb-3">
            <div class="card mb-3">
                <div class="card-header"><h2 class="h6 mb-0">Library</h2></div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-primary" href="@_libraryUrl" target="_blank">
                            <i class="bi bi-box-arrow-up-right me-1"></i>Open Library
                        </a>
                        <button type="button" class="btn btn-outline-secondary" @onclick="RebuildReport" disabled="@_rebuilding">
                            <i class="bi bi-arrow-repeat me-1"></i>@(_rebuilding ? "Requesting…" : "Rebuild Report")
                        </button>
                    </div>
                    @if (_rebuildMessage is not null)
                    {
                        <div class="alert alert-success py-2 mt-2 mb-0">@_rebuildMessage</div>
                    }
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h2 class="h6 mb-0">Add a Video</h2></div>
                <div class="card-body">
                    <AddVideoForm ProjectId="_project.Id" OnVideoAdded="RefreshVideos" />
                </div>
            </div>

            <div class="card border-danger">
                <div class="card-header text-danger"><h2 class="h6 mb-0">Delete Project</h2></div>
                <div class="card-body">
                    @if (!_confirmingDelete)
                    {
                        <button class="btn btn-outline-danger" @onclick="() => _confirmingDelete = true">Delete Project</button>
                    }
                    else
                    {
                        <p>Delete <strong>@_project.Name</strong> from Video Cortex?</p>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="alsoDelete" @bind="_alsoDeleteFolder" />
                            <label class="form-check-label small" for="alsoDelete">
                                Also delete the library folder on disk (by default the OKF files are kept)
                            </label>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_deleting">
                                @(_deleting ? "Deleting…" : "Confirm Delete")
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="() => _confirmingDelete = false" disabled="@_deleting">Cancel</button>
                        </div>
                        @if (_error is not null)
                        {
                            <div class="alert alert-warning py-2 mt-2 mb-0">@_error</div>
                        }
                    }
                </div>
            </div>
        </aside>

        <section class="col-lg-9 col-md-8">
            <h1 class="mb-1">@_project.Name</h1>
            @if (!string.IsNullOrWhiteSpace(_project.Description))
            {
                <p class="mb-1"><strong>Description:</strong> @_project.Description</p>
            }
            @if (!string.IsNullOrWhiteSpace(_project.AIInstructions))
            {
                <p class="mb-1"><strong>AI Instructions:</strong> @_project.AIInstructions</p>
            }
            <p class="text-body-secondary small mb-1">
                Created @_project.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd") · Status: @_project.Status
            </p>
            <p class="text-body-secondary small text-break">Library: <code>@_libraryPath</code></p>

            <div class="card">
                <div class="card-body">
                    <ProjectVideos @ref="_videos" ProjectId="_project.Id" LibraryFolderName="@_project.LibraryFolderName" OnChanged="RefreshVideos" />
                </div>
            </div>
        </section>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private ProjectDetailDto? _project;
    private ProjectVideos? _videos;
    private bool _loading = true;
    private bool _confirmingDelete;
    private bool _alsoDeleteFolder;
    private bool _deleting;
    private string? _error;
    private string _libraryPath = string.Empty;
    private string _libraryUrl = string.Empty;
    private bool _rebuilding;
    private string? _rebuildMessage;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _project = await ProjectService.GetBySlugAsync(Slug);
        if (_project is not null)
        {
            _libraryPath = Path.Combine(LibraryOptions.Value.RootPath, _project.LibraryFolderName, "index.html");
            _libraryUrl = LibraryUrls.ForProject(_project.LibraryFolderName);
        }
        _loading = false;
    }

    private async Task RebuildReport()
    {
        _rebuilding = true;
        _rebuildMessage = null;
        try
        {
            await ProjectService.RequestReportRebuildAsync(_project!.Id);
            _rebuildMessage = "Report rebuild requested — it will regenerate shortly.";
        }
        finally
        {
            _rebuilding = false;
        }
    }

    private async Task RefreshVideos()
    {
        if (_videos is not null)
            await _videos.RefreshAsync();
    }

    private async Task ConfirmDelete()
    {
        _deleting = true;
        _error = null;
        var result = await ProjectService.DeleteAsync(_project!.Id, _alsoDeleteFolder);
        if (result.Success)
        {
            Nav.NavigateTo("/projects");
        }
        else
        {
            _error = result.ErrorMessage ?? "Delete failed.";
            _deleting = false;
        }
    }
}
