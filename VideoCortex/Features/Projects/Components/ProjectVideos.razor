@using System.IO
@inject IVideoQueries VideoQueries
@inject IVideoCommands VideoCommands
@inject IVideoRetryCommand VideoRetry
@inject IDesktopFileOpener FileOpener

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="h5 mb-0">Videos @(_videos is not null ? $"({_videos.Count})" : "")</h3>
    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="RefreshAsync" disabled="@_loading">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
</div>

@if (_loading && _videos is null)
{
    <p class="text-body-secondary">Loading…</p>
}
else if (_videos is null || _videos.Count == 0)
{
    <p class="text-body-secondary">No videos in this project yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr><th>Video</th><th>Status</th><th>Added</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var v in _videos)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(v.Title))
                            {
                                @v.Title
                            }
                            else
                            {
                                <code>@v.YoutubeVideoId</code>
                            }
                            @if (ConceptPath(v) is { } path)
                            {
                                <button type="button" class="linklike small ms-1" @onclick="() => OpenConcept(path)">open ↗</button>
                            }
                            @if (NeedsRetry(v) && !string.IsNullOrWhiteSpace(v.LastError))
                            {
                                <div class="text-danger small" title="@v.LastError">@Truncate(v.LastError!, 120)</div>
                            }
                        </td>
                        <td><span class="badge @BadgeClass(v.Status)">@Label(v.Status)</span></td>
                        <td class="text-body-secondary small">@v.AddedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end text-nowrap">
                            @if (NeedsRetry(v))
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => RetryAsync(v.Id)" disabled="@_busy">Retry</button>
                            }
                            @if (_confirmingId == v.Id)
                            {
                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveAsync(v.Id)" disabled="@_busy">Confirm</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmingId = null" disabled="@_busy">Cancel</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmingId = v.Id">Remove</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public int ProjectId { get; set; }

    /// <summary>Absolute path to the project's on-disk library folder, for building open-page links.</summary>
    [Parameter] public string? LibraryDir { get; set; }

    /// <summary>Invoked after a video is removed, so the parent can refresh related state.</summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    private IReadOnlyList<VideoRowDto>? _videos;
    private bool _loading;
    private bool _busy;
    private int? _confirmingId;
    private int _loadedProjectId;

    protected override async Task OnParametersSetAsync()
    {
        if (_videos is null || _loadedProjectId != ProjectId)
        {
            _loadedProjectId = ProjectId;
            await RefreshAsync();
        }
    }

    public async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            _videos = await VideoQueries.ListForProjectAsync(ProjectId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RetryAsync(int videoId)
    {
        _busy = true;
        try
        {
            await VideoRetry.RetryVideoAsync(videoId);
            await RefreshAsync();
            await OnChanged.InvokeAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveAsync(int videoId)
    {
        _busy = true;
        try
        {
            await VideoCommands.RemoveVideoAsync(videoId);
            _confirmingId = null;
            await RefreshAsync();
            await OnChanged.InvokeAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private string? ConceptPath(VideoRowDto v)
    {
        if (string.IsNullOrWhiteSpace(v.ConceptSlug) || string.IsNullOrWhiteSpace(LibraryDir)) return null;
        return Path.Combine(LibraryDir, v.ConceptSlug + ".html");
    }

    private void OpenConcept(string path) => FileOpener.TryOpen(path, out _);

    private static bool NeedsRetry(VideoRowDto v)
        => v.Parked || v.Status is VideoStatus.Error or VideoStatus.NoTranscript;

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";

    private static string Label(VideoStatus status) => status switch
    {
        VideoStatus.Added => "Added",
        VideoStatus.Transcribed => "Transcribed",
        VideoStatus.Summarized => "Summarized",
        VideoStatus.Published => "Published",
        VideoStatus.NoTranscript => "No transcript",
        VideoStatus.Error => "Error",
        _ => status.ToString(),
    };

    private static string BadgeClass(VideoStatus status) => status switch
    {
        VideoStatus.Published => "text-bg-success",
        VideoStatus.NoTranscript or VideoStatus.Error => "text-bg-danger",
        VideoStatus.Summarized => "text-bg-info",
        _ => "text-bg-secondary",
    };
}
