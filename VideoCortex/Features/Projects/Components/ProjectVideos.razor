@implements IDisposable
@inject IVideoQueries VideoQueries
@inject IVideoCommands VideoCommands
@inject IVideoRetryCommand VideoRetry

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h6 mb-0">Videos @(_videos is not null ? $"({_videos.Count})" : "")</h2>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => RefreshAsync()" disabled="@_loading">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
    <div class="card-body">
        @if (_loading && _videos is null)
        {
            <p class="text-body-secondary mb-0">Loading…</p>
        }
        else if (_videos is null || _videos.Count == 0)
        {
            <p class="text-body-secondary mb-0">No videos in this project yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr><th>Video</th><th>Status</th><th>Added</th><th class="text-end">Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var v in _videos)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(v.Title))
                                    {
                                        @v.Title
                                    }
                                    else
                                    {
                                        <code>@v.YoutubeVideoId</code>
                                    }
                                    @if (ConceptUrl(v) is { } url)
                                    {
                                        <a class="small ms-1" href="@url" target="_blank">open ↗</a>
                                    }
                                    @if (NeedsRetry(v) && !string.IsNullOrWhiteSpace(v.LastError))
                                    {
                                        <div class="text-danger small" title="@v.LastError">@Truncate(v.LastError!, 120)</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge @BadgeClass(v.Status)">@Label(v.Status)</span>
                                    @if (IsInProgress(v))
                                    {
                                        <span class="spinner-border spinner-border-sm text-body-secondary ms-1" style="width:.75rem;height:.75rem;" role="status" aria-hidden="true"></span>
                                    }
                                </td>
                                <td class="text-body-secondary small">@v.AddedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end text-nowrap">
                                    @if (NeedsRetry(v))
                                    {
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => RetryAsync(v.Id)" disabled="@_busy">Retry</button>
                                    }
                                    @if (_confirmingId == v.Id)
                                    {
                                        <button class="btn btn-sm btn-danger" @onclick="() => RemoveAsync(v.Id)" disabled="@_busy">Confirm</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmingId = null" disabled="@_busy">Cancel</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmingId = v.Id">Remove</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    /// <summary>The project's library folder name, for building hosted open-page links.</summary>
    [Parameter] public string? LibraryFolderName { get; set; }

    /// <summary>Invoked after a video is removed, so the parent can refresh related state.</summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    /// <summary>How often to re-poll the database while videos are still being processed.</summary>
    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(3);

    private IReadOnlyList<VideoRowDto>? _videos;
    private bool _loading;
    private bool _busy;
    private int? _confirmingId;
    private int _loadedProjectId;
    private System.Timers.Timer? _pollTimer;
    private bool _polling;

    protected override async Task OnParametersSetAsync()
    {
        if (_videos is null || _loadedProjectId != ProjectId)
        {
            _loadedProjectId = ProjectId;
            await RefreshAsync();
        }
    }

    /// <param name="showLoading">
    /// True for user-initiated refreshes (disables the Refresh button); false for silent background polls.
    /// </param>
    public async Task RefreshAsync(bool showLoading = true)
    {
        if (showLoading) _loading = true;
        try
        {
            _videos = await VideoQueries.ListForProjectAsync(ProjectId);
        }
        finally
        {
            if (showLoading) _loading = false;
        }
        UpdatePolling();
    }

    /// <summary>Starts background polling while any video is mid-pipeline; stops it once everything settles.</summary>
    private void UpdatePolling()
    {
        var shouldPoll = _videos?.Any(IsInProgress) ?? false;
        if (shouldPoll == _polling) return;

        _polling = shouldPoll;
        if (shouldPoll)
        {
            _pollTimer = new System.Timers.Timer(PollInterval.TotalMilliseconds) { AutoReset = true };
            _pollTimer.Elapsed += OnPollElapsed;
            _pollTimer.Start();
        }
        else
        {
            StopTimer();
        }
    }

    private async void OnPollElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        // Timer fires on a thread-pool thread; marshal back onto the render sync context.
        await InvokeAsync(async () =>
        {
            await RefreshAsync(showLoading: false);
            StateHasChanged();
        });
    }

    private void StopTimer()
    {
        if (_pollTimer is null) return;
        _pollTimer.Elapsed -= OnPollElapsed;
        _pollTimer.Dispose();
        _pollTimer = null;
    }

    /// <summary>A video still moving through the pipeline (waiting on a worker), so the row should keep refreshing.</summary>
    private static bool IsInProgress(VideoRowDto v)
        => !v.Parked && v.Status is VideoStatus.Added or VideoStatus.Transcribed or VideoStatus.Summarized;

    public void Dispose() => StopTimer();

    private async Task RetryAsync(int videoId)
    {
        _busy = true;
        try
        {
            await VideoRetry.RetryVideoAsync(videoId);
            await RefreshAsync();
            await OnChanged.InvokeAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveAsync(int videoId)
    {
        _busy = true;
        try
        {
            await VideoCommands.RemoveVideoAsync(videoId);
            _confirmingId = null;
            await RefreshAsync();
            await OnChanged.InvokeAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private string? ConceptUrl(VideoRowDto v)
    {
        if (string.IsNullOrWhiteSpace(v.ConceptSlug) || string.IsNullOrWhiteSpace(LibraryFolderName)) return null;
        return LibraryUrls.ForConcept(LibraryFolderName, v.ConceptSlug);
    }

    private static bool NeedsRetry(VideoRowDto v)
        => v.Parked || v.Status is VideoStatus.Error or VideoStatus.NoTranscript;

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";

    private static string Label(VideoStatus status) => status switch
    {
        VideoStatus.Added => "Added",
        VideoStatus.Transcribed => "Transcribed",
        VideoStatus.Summarized => "Summarized",
        VideoStatus.Published => "Published",
        VideoStatus.NoTranscript => "No transcript",
        VideoStatus.Error => "Error",
        _ => status.ToString(),
    };

    private static string BadgeClass(VideoStatus status) => status switch
    {
        VideoStatus.Published => "text-bg-success",
        VideoStatus.NoTranscript or VideoStatus.Error => "text-bg-danger",
        VideoStatus.Summarized => "text-bg-info",
        _ => "text-bg-secondary",
    };
}
