@using System.IO
@inject IVideoQueries VideoQueries
@inject IVideoCommands VideoCommands

<div class="videos-header">
    <h3>Videos @(_videos is not null ? $"({_videos.Count})" : "")</h3>
    <button type="button" @onclick="RefreshAsync" disabled="@_loading">Refresh</button>
</div>

@if (_loading && _videos is null)
{
    <p class="muted">Loading…</p>
}
else if (_videos is null || _videos.Count == 0)
{
    <p class="muted">No videos in this project yet.</p>
}
else
{
    <table class="videos">
        <thead>
            <tr><th>Video</th><th>Status</th><th>Added</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var v in _videos)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(v.Title))
                        {
                            @v.Title
                        }
                        else
                        {
                            <code>@v.YoutubeVideoId</code>
                        }
                        @if (ConceptHref(v) is { } href)
                        {
                            <a class="small" href="@href" target="_blank" rel="noopener"> open ↗</a>
                        }
                    </td>
                    <td><span class="badge @BadgeClass(v.Status)">@Label(v.Status)</span></td>
                    <td class="meta">@v.AddedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (_confirmingId == v.Id)
                        {
                            <button class="btn-danger small" @onclick="() => RemoveAsync(v.Id)" disabled="@_busy">Confirm</button>
                            <button class="small" @onclick="() => _confirmingId = null" disabled="@_busy">Cancel</button>
                        }
                        else
                        {
                            <button class="small" @onclick="() => _confirmingId = v.Id">Remove</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public int ProjectId { get; set; }

    /// <summary>Absolute path to the project's on-disk library folder, for building open-page links.</summary>
    [Parameter] public string? LibraryDir { get; set; }

    /// <summary>Invoked after a video is removed, so the parent can refresh related state.</summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    private IReadOnlyList<VideoRowDto>? _videos;
    private bool _loading;
    private bool _busy;
    private int? _confirmingId;
    private int _loadedProjectId;

    protected override async Task OnParametersSetAsync()
    {
        if (_videos is null || _loadedProjectId != ProjectId)
        {
            _loadedProjectId = ProjectId;
            await RefreshAsync();
        }
    }

    public async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            _videos = await VideoQueries.ListForProjectAsync(ProjectId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RemoveAsync(int videoId)
    {
        _busy = true;
        try
        {
            await VideoCommands.RemoveVideoAsync(videoId);
            _confirmingId = null;
            await RefreshAsync();
            await OnChanged.InvokeAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private string? ConceptHref(VideoRowDto v)
    {
        if (string.IsNullOrWhiteSpace(v.ConceptSlug) || string.IsNullOrWhiteSpace(LibraryDir)) return null;
        return new Uri(Path.Combine(LibraryDir, v.ConceptSlug + ".html")).AbsoluteUri;
    }

    private static string Label(VideoStatus status) => status switch
    {
        VideoStatus.Added => "Added",
        VideoStatus.Transcribed => "Transcribed",
        VideoStatus.Summarized => "Summarized",
        VideoStatus.Published => "Published",
        VideoStatus.NoTranscript => "No transcript",
        VideoStatus.Error => "Error",
        _ => status.ToString(),
    };

    private static string BadgeClass(VideoStatus status) => status switch
    {
        VideoStatus.Published => "badge-done",
        VideoStatus.NoTranscript or VideoStatus.Error => "badge-warn",
        _ => "badge-neutral",
    };
}
